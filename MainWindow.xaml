<Window x:Class="PetrolStationNetwork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetrolStationNetwork"
        mc:Ignorable="d"
        Title="Управление запасами и ассортиментом АЗС" Height="550" Width="800" MinHeight="550" MinWidth="800">
    <Grid Background="#f0f0f0">
        <Grid Height="50" VerticalAlignment="Top" Background="White">
            <Grid.Effect>
                <DropShadowEffect Opacity="0.1"/>
            </Grid.Effect>
            <Image Width="30" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" />
            <Label Content="АЗС" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="18" />
        </Grid>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,55,0,0"/>
    </Grid>
</Window>
