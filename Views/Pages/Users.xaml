<Page x:Class="PetrolStationNetwork.Views.Pages.Users"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PetrolStationNetwork.Views.Pages"
      xmlns:elements="clr-namespace:PetrolStationNetwork.Views.Components"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Users">

    <Grid Background="White">
        <Label Grid.Row="0"
            Content="Все пользователи"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#1565C0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top" Width="780" Grid.ColumnSpan="2" Margin="10,0,0,0"/>

        <Button
             Command="{Binding Exit}"
             Content="Назад"
             Background="#F44336"
             Foreground="White"
             BorderThickness="0"
             FontSize="14"
             FontWeight="SemiBold"
             Padding="0"
             Width="75"
             Height="25"
             Cursor="Hand"
             HorizontalContentAlignment="Center"
             VerticalAlignment="Bottom"
             HorizontalAlignment="Left"
             Margin="10,0,0,10">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>

        <ListView ItemsSource="{Binding Users}"
       HorizontalContentAlignment="Stretch" Margin="10,50,10,45"
       BorderThickness="0" Padding="0" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:User DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
