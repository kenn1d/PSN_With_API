<Page x:Class="PetrolStationNetwork.Views.Pages.Deliveries"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PetrolStationNetwork.Views.Pages"
      xmlns:elements="clr-namespace:PetrolStationNetwork.Views.Components"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Deliveries">
    
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0"
           Content="Все поставки"
           FontSize="28"
           FontWeight="SemiBold"
           Foreground="#1565C0"
           HorizontalAlignment="Left"
           VerticalAlignment="Top" Width="780" Grid.ColumnSpan="2" Margin="10,0,0,0"/>

        <Button
            Command="{Binding Exit}"
            Content="Назад"
            Background="#F44336"
            Foreground="White"
            BorderThickness="0"
            FontSize="14"
            FontWeight="SemiBold"
            Padding="0"
            Width="75"
            Height="25"
            Cursor="Hand"
            HorizontalContentAlignment="Center"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Left"
            Margin="10,0,0,10">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>

        <ListView ItemsSource="{Binding Deliveries}" SelectedItem="{Binding SelectedItem}"
                  HorizontalContentAlignment="Stretch" Margin="10,50,10,45" Grid.Column="0"
                  BorderThickness="0" Padding="0" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Delivery DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Column="1" Margin="0,50,0,10">
            <Label Foreground="#1565C0" VerticalAlignment="Top" HorizontalAlignment="Left" Content="Серия и номер:" Margin="10,0,0,0" />
            <TextBox x:Name="serialNumber" BorderBrush="#64B5F6" Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Margin="10,26,10,0" Height="26" IsEnabled="False" />

            <Label Foreground="#1565C0" VerticalAlignment="Top" HorizontalAlignment="Left" Content="Статус:" Margin="10,60,0,0" />
            <ComboBox x:Name="status" BorderBrush="#64B5F6" VerticalAlignment="Top" 
                      Margin="10,86,10,0" Height="26" IsEnabled="False" SelectedValue="{Binding SelectedStatus, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" SelectedIndex="0">
                <ComboBoxItem>В ожидании</ComboBoxItem>
                <ComboBoxItem>В обработке</ComboBoxItem>
                <ComboBoxItem>Принята</ComboBoxItem>
                <ComboBoxItem>Отменена</ComboBoxItem>
            </ComboBox>

            <Button x:Name="bthAdd"
                    Command="{Binding Add}"
                    Height="25" 
                    VerticalAlignment="Bottom" 
                    Width="80" 
                    Margin="0,0,10,0" 
                    FontSize="14"
                    HorizontalAlignment="Right" 
                    Content="{Binding BthAddContent}" 
                    BorderThickness="0"
                    Background="#2196F3"
                    FontWeight="SemiBold"
                    Foreground="White" IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="bthDelete"
                Command="{Binding OnDelete}"
                Height="25" 
                VerticalAlignment="Bottom" 
                Width="80" 
                Margin="10,0,110,0" 
                FontSize="14"
                HorizontalAlignment="Left" 
                Content="Удалить" 
                BorderThickness="0"
                Background="#F44336"
                FontWeight="SemiBold"
                Foreground="White" IsEnabled="False">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Page>
