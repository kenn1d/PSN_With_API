<Page x:Class="PetrolStationNetwork.Views.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PetrolStationNetwork.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid Background="White">
        <Label Grid.Row="0"
           Content="{Binding UserFIO}"
           FontSize="28"
           FontWeight="SemiBold"
           Foreground="#1565C0"
           HorizontalAlignment="Center"
               HorizontalContentAlignment="Center"
           VerticalAlignment="Top"/>
        <Grid x:Name="buttons" Width="780" Margin="10,55,0,35" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="Deliveries"
                Command="{Binding Deliveries}"
                Content="Все поставки"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,10,10,0" Grid.Column="0" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="DeliveryItems"
                Command="{Binding DeliveryItems}"
                Content="Элементы поставок"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,55,10,0" Grid.Column="0" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="Products"
                Command="{Binding Products}"
                Content="Все продукты"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,100,10,0" Grid.Column="0" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="WarehouseItems"
                Command="{Binding WarehouseItems}"
                Content="Продукция на складе"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,10,10,0" Grid.Column="1" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="ShopItems"
                Command="{Binding ShopItems}"
                Content="Продукция в зале"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,55,10,0" Grid.Column="1" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="Users"
                Command="{Binding Users}"
                Content="Все пользователи"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,10,10,0" Grid.Column="2" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="Suppliers"
                Command="{Binding Suppliers}"
                Content="Поставщики"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,55,10,0" Grid.Column="2" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="Staff"
                Command="{Binding Staff}"
                Content="Персонал"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                FontSize="16"
                FontWeight="SemiBold"
                Padding="0"
                Cursor="Hand"
                HorizontalContentAlignment="Center" Margin="10,100,10,0" Grid.Column="2" IsEnabled="False" Height="35" VerticalAlignment="Top">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Button
        Command="{Binding Exit}"
        Content="Выйти"
        Background="#F44336"
        Foreground="White"
        BorderThickness="0"
        FontSize="14"
        FontWeight="SemiBold"
        Padding="0"
        Width="74"
        Cursor="Hand"
        HorizontalContentAlignment="Center"
        HorizontalAlignment="Center" Margin="0,0,0,5" Height="25" VerticalAlignment="Bottom">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Page>
