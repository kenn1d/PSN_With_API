<UserControl x:Class="PetrolStationNetwork.Views.Components.Supplier"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetrolStationNetwork.Views.Components"
             mc:Ignorable="d" >
    <Grid Margin="5" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/images/supplier.jpg" Grid.Column="0" Stretch="Uniform"/>

        <StackPanel Grid.Column="1" Margin="5,5,5,5">
            <Label Content="Пользователь"
FontWeight="Bold"
FontSize="14"
VerticalAlignment="Top"
HorizontalAlignment="Left"
Padding="0,2,0,0"/>
            <Label Content="{Binding FullName}"
FontSize="14" Height="20"
HorizontalAlignment="Left"
FontStyle="Italic"
Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="5,5,5,5">
            <Label Content="Название компании"
FontWeight="Bold"
FontSize="14"
VerticalAlignment="Top"
HorizontalAlignment="Left"
Padding="0,2,0,0"/>
            <Label Content="{Binding Company_name}"
FontSize="14" Height="20"
HorizontalAlignment="Left"
FontStyle="Italic"
Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
