<UserControl x:Class="PetrolStationNetwork.Views.Components.DeliveryItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetrolStationNetwork.Views.Components"
             mc:Ignorable="d" >
    <Grid Margin="5" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/Images/icon-black.png" Grid.Column="0" Stretch="Uniform"/>

        <StackPanel Grid.Column="1" Margin="5,5,5,5">
            <Label Content="Поставка"
       FontWeight="Bold"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       Padding="0,2,0,0"/>
            <Label Content="{Binding SerialNumber}" Height="20"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       FontStyle="Italic"
       Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="5,5,5,5">
            <Label Content="Продукт"
       FontWeight="Bold"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       Padding="0,2,0,0"/>
            <Label Content="{Binding ProductName}" Height="20"
       FontSize="14"
       HorizontalAlignment="Left"
       FontStyle="Italic"
       Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Margin="5,5,5,5">
            <Label Content="Количество"
       FontWeight="Bold"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       Padding="0,2,0,0"/>
            <Label Content="{Binding Count}" Height="20"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       FontStyle="Italic"
       Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Column="4" Margin="5,5,5,5">
            <Label Content="Срок годности"
       FontWeight="Bold"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       Padding="0,2,0,0"/>
            <Label Content="{Binding Exp_date}" Height="20"
       FontSize="14"
       VerticalAlignment="Top"
       HorizontalAlignment="Left"
       FontStyle="Italic"
       Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
