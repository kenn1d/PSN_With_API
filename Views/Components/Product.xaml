<UserControl x:Class="PetrolStationNetwork.Views.Components.Product"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PetrolStationNetwork.Views.Components"
             mc:Ignorable="d" >
    <Grid Margin="5" Background="White" Height="50">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Source="/images/product.png" Grid.Column="0" Stretch="Uniform"/>

        <StackPanel Grid.Column="1" Margin="5,5,5,5">
            <Label Content="Наименование"
   FontWeight="Bold"
   FontSize="14"
   VerticalAlignment="Top"
   HorizontalAlignment="Left"
   Padding="0,2,0,0"/>
            <Label Content="{Binding Name}"
   FontSize="14"
   Height="20"
   HorizontalAlignment="Left"
   FontStyle="Italic"
   Padding="0,0,0,2" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</UserControl>
